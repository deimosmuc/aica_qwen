# Copy to .env and fill in to enable real Qwen mode.
# Leave QWEN_API_KEY empty (or delete .env) to run in Mock Mode — the demo
# still works fully with prepared example data.

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- API Guard (controls cost; all optional, sensible defaults built in) ----
GUARD_ENABLED=true
GUARD_BUDGET_USD=35.0           # hard total spend cap; calls blocked beyond it
GUARD_MAX_OUTPUT_TOKENS=6000    # max answer length per call
GUARD_RATE_PER_MINUTE=15
GUARD_RATE_PER_DAY=250
# Price ESTIMATES per 1K tokens (kept slightly high so the cap errs safe).
# Confirm against the current Qwen price page.
GUARD_PRICE_IN_PER_1K=0.001
GUARD_PRICE_OUT_PER_1K=0.002
