# Copy this to  app.env  ON THE SERVER and fill in real values.
# app.env is gitignored and must NEVER be committed.

# The image built by the GitHub Action. Use your GitHub user + repo name, lowercase.
APP_IMAGE=ghcr.io/<your-github-user>/<your-repo>:latest

# --- Qwen (live mode) ---------------------------------------------------------
# Leave QWEN_API_KEY empty to run in Mock Mode (demo still works fully).
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- API Guard (cost cap; sensible defaults built in) -------------------------
GUARD_ENABLED=true
# Response caching. false = every run is a genuine live Qwen call (no instant
# "cached" replays that could look canned to jurors). The live demo runs with this
# OFF. A full run is only ~$0.07-0.12, so hundreds of runs still fit GUARD_BUDGET_USD.
GUARD_CACHE_ENABLED=false
GUARD_BUDGET_USD=35.0           # hard total spend cap; calls blocked beyond it
GUARD_MAX_OUTPUT_TOKENS=6000
GUARD_RATE_PER_MINUTE=15
GUARD_RATE_PER_DAY=250
GUARD_PRICE_IN_PER_1K=0.001
GUARD_PRICE_OUT_PER_1K=0.002
