# Copy this to  caddy.env  ON THE SERVER and fill in real values.
# caddy.env is gitignored and must NEVER be committed.

# The username the jurors will type.
BASIC_AUTH_USER=juror

# The password HASH (never the plaintext password).
# Generate it on the server with:
#   docker run --rm caddy caddy hash-password --plaintext '<your-juror-password>'
# Then paste the output after the = sign below.
BASIC_AUTH_HASH=
